public class Patterns{
    public static void pattern01(int n){
        for(int i=1;i<=n;i++){
            for(int j=1;j<=n;j++){
                System.out.print("* ");
            }
            System.out.println();
        }
    } 
    public static void main(String args[]){
        pattern01(5);
    }
}
